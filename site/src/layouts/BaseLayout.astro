---
import '../styles/global.css';
import {
  canonicalOrigin,
  contact,
  education,
  experiences,
  knowsAbout,
  profile,
} from '../data/resume';

interface Props {
  title: string;
  description: string;
  ogType?: string;
  robots?: string;
  includePersonSchema?: boolean;
  includeWebsiteSchema?: boolean;
  pageJsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  ogType = 'website',
  robots,
  includePersonSchema = false,
  includeWebsiteSchema = false,
  pageJsonLd = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og.png', Astro.site);

// Cookieless Umami analytics - rendered only when configured (see
// analytics/README.md), so the default build ships no tracking at all.
const umamiSrc = import.meta.env.PUBLIC_UMAMI_SRC as string | undefined;
const umamiId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID as string | undefined;
const analyticsEnabled = Boolean(umamiSrc && umamiId);

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  jobTitle: profile.title,
  description: profile.tagline,
  url: canonicalOrigin,
  email: `mailto:${contact.email}`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Istanbul',
    addressCountry: 'TR',
  },
  sameAs: [contact.linkedin, contact.github],
  knowsAbout,
  alumniOf: education.map((entry) => ({
    '@type': 'CollegeOrUniversity',
    name: entry.institution,
  })),
  worksFor: experiences
    .filter((entry) => entry.end === null)
    .map((entry) => ({ '@type': 'Organization', name: entry.company })),
  hasOccupation: experiences.map((entry) => ({
    '@type': 'EmployeeRole',
    roleName: entry.role,
    startDate: entry.start,
    ...(entry.end ? { endDate: entry.end } : {}),
    worksFor: { '@type': 'Organization', name: entry.company },
  })),
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'casim.net',
  url: canonicalOrigin,
};

const rawSchemas = [
  ...(includePersonSchema ? [personJsonLd] : []),
  ...(includeWebsiteSchema ? [websiteJsonLd] : []),
  ...(Array.isArray(pageJsonLd) ? pageJsonLd : [pageJsonLd]),
].filter(Boolean);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="preload"
      href="/fonts/InterVariable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${profile.name} - ${profile.title}`} />
    <meta property="og:site_name" content="casim.net" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {rawSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    {analyticsEnabled && (
      // crossorigin: the site runs cross-origin isolated (COEP require-corp,
      // needed by WebLLM in the Flutter island) - the stats host must answer
      // CORS (see analytics/README.md).
      <script
        is:inline
        defer
        crossorigin="anonymous"
        src={umamiSrc}
        data-website-id={umamiId}
        data-do-not-track="true"
      />
    )}
    {analyticsEnabled && (
      // Section-visibility events: fires `section-view` once per section per
      // visit. data-umami-event clicks (nav, hero, contact, chat) are handled
      // by the Umami script itself.
      <script is:inline>
        addEventListener('load', () => {
          const seen = new Set();
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                const id = entry.target.id;
                if (entry.isIntersecting && !seen.has(id)) {
                  seen.add(id);
                  window.umami?.track('section-view', { section: id });
                }
              }
            },
            { threshold: 0.1 }
          );
          document.querySelectorAll('main section[id]').forEach((s) => io.observe(s));
        });
      </script>
    )}

    <!-- Apply the saved theme before first paint to avoid a flash.
         This plus the toggle handler is the only client-side JS on the site. -->
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const theme =
          stored ??
          (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
  </body>
</html>

---
import {
  caseStudies,
  getCaseStudyContext,
  getCaseStudyPath,
  getCaseStudyPeriodLabel,
} from '../data/resume';
---

<section id="case-studies" class="section" aria-labelledby="case-studies-heading">
  <h2 id="case-studies-heading">Case Studies</h2>
  <div class="grid">
    {caseStudies.map((caseStudy) => {
      const periodLabel = getCaseStudyPeriodLabel(caseStudy);

      return (
        <article class="card">
          <h3>
            <a class="title-link" href={getCaseStudyPath(caseStudy)}>
              {caseStudy.title}
            </a>
          </h3>
          <p class="client muted">
            {getCaseStudyContext(caseStudy)}
            {periodLabel && <span> · {periodLabel}</span>}
          </p>
          <p>{caseStudy.summary}</p>
          <ul class="chip-list" aria-label={`Technologies used for ${caseStudy.title}`}>
            {caseStudy.stack.map((tech) => (
              <li><span class="chip">{tech}</span></li>
            ))}
          </ul>
          <p class="cta-row">
            <a class="button-secondary" href={getCaseStudyPath(caseStudy)}>
              Read full case study
            </a>
          </p>
        </article>
      );
    })}
  </div>
</section>

<style>
  .grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 20rem), 1fr));
  }

  .title-link {
    color: inherit;
    text-decoration: none;
  }

  .title-link:hover,
  .title-link:focus-visible {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .client {
    margin: var(--space-1) 0 var(--space-4);
    font-size: var(--text-small);
  }

  .cta-row {
    margin: var(--space-4) 0 0;
  }
</style>

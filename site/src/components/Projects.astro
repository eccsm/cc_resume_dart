---
import { getProjectPath, projects } from '../data/resume';
---

<section id="projects" class="section" aria-labelledby="projects-heading">
  <h2 id="projects-heading">Projects</h2>
  <div class="grid">
    {projects.map((project) => (
      <article class="card project-card">
        <div class="card-header">
          <div>
            <p class="status-chip">{project.statusLabel}</p>
            <h3>
              <a class="title-link" href={getProjectPath(project)}>
                {project.name}
              </a>
            </h3>
            <p class="tagline">{project.tagline}</p>
          </div>
        </div>
        <p>{project.shortSummary}</p>
        <ul class="chip-list" aria-label={`Technologies used in ${project.name}`}>
          {project.technologies.slice(0, 5).map((tech) => (
            <li><span class="chip">{tech}</span></li>
          ))}
        </ul>
        <p class="cta-row">
          <a class="button-secondary" href={getProjectPath(project)}>
            Read the {project.name} project page
          </a>
        </p>
      </article>
    ))}
  </div>
</section>

<style>
  .grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 20rem), 1fr));
  }

  .project-card {
    display: grid;
    gap: var(--space-4);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    align-items: start;
  }

  .status-chip {
    display: inline-block;
    margin: 0 0 var(--space-2);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-chip);
    background: var(--color-chip-bg);
    color: var(--color-chip-text);
    font-family: var(--font-mono);
    font-size: var(--text-chip);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .title-link {
    color: inherit;
    text-decoration: none;
  }

  .title-link:hover,
  .title-link:focus-visible {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .tagline {
    margin: var(--space-2) 0 0;
    color: var(--color-text-muted);
    font-size: var(--text-small);
  }

  .cta-row {
    margin: 0;
  }
</style>

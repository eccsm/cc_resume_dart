# Copy to .env (git-ignored). All values are optional — features whose vars
# are unset simply don't render, keeping the site static and JS-free.

# Umami analytics (see ../analytics). Enables the tracking script.
PUBLIC_UMAMI_SRC=https://stats.casim.net/script.js
PUBLIC_UMAMI_WEBSITE_ID=

# IndexNow is configured as a GitHub Actions secret (`INDEXNOW_KEY`) rather
# than a committed runtime env file. For local dry-runs or manual submissions,
# export it in your shell before running the IndexNow scripts.
# INDEXNOW_KEY=

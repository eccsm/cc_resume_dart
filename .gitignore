# Repo-wide rules only — project-specific rules live in each project's own
# .gitignore (flutter_app/, site/, worker/).

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
*.iml

# Logs
*.log

# Node
node_modules/

# Firebase local artifacts
.firebase/
firebase-debug.log
firebase-debug.*.log

# Secrets / env files (examples stay tracked)
.env
.env.*
*.env
!.env.example
